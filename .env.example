# Copy this file to .env and fill in your values
# Never commit .env to git

# REQUIRED: Custom cipher secret key — use a long random string in production
EMIS_SECRET_KEY=change-me-to-a-long-random-string

# OPTIONAL: MongoDB Atlas connection string
# Leave empty to use in-memory store (for local dev / testing)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/emis?retryWrites=true&w=majority

# OPTIONAL: Redis URL for Celery async task queue (bonus feature)
# Leave empty to disable async mode and use synchronous processing
REDIS_URL=redis://localhost:6379/0

# MongoDB database name
MONGO_DB_NAME=emis
